@page "/"
@inject IDbContextFactory<DevLeadsDbContext> DbFactory
<PageTitle>Dashboard · DevLeads</PageTitle>

<div class="rr-page-head">
    <div>
        <h1>Command center</h1>
        <div class="rr-sub">
            @if (_campaign is not null)
            {
                <span>@_campaign.Emoji <strong>@_campaign.Name</strong> — @(string.IsNullOrWhiteSpace(_campaign.Objective) ? "no objective set" : Truncate(_campaign.Objective, 140))</span>
            }
            else
            {
                <span>🌐 All campaigns combined. Discover paid engagements and owner-networking opportunities, triage cheaply, respond specifically.</span>
            }
        </div>
    </div>
    <a class="rr-btn primary" href="opportunities">View all leads →</a>
</div>

@if (_loading)
{
    <div class="rr-empty">Loading…</div>
}
else
{
    <div class="rr-cards">
        <div class="rr-card crit">
            <div class="k">Critical now</div>
            <div class="v">@_criticalCount</div>
            <div class="foot">Immediate alert band (85–100)</div>
        </div>
        <div class="rr-card accent">
            <div class="k">New high-score</div>
            <div class="v">@_highCount</div>
            <div class="foot">Score ≥ 70, awaiting action</div>
        </div>
        <div class="rr-card">
            <div class="k">Drafts to approve</div>
            <div class="v">@_draftsPending</div>
            <div class="foot"><a href="drafts">Approval queue →</a></div>
        </div>
        <div class="rr-card">
            <div class="k">AI review needed</div>
            <div class="v">@_aiReview</div>
            <div class="foot">Triage failed / low confidence</div>
        </div>
        <div class="rr-card">
            <div class="k">Contacted</div>
            <div class="v">@_contacted</div>
            <div class="foot">@_replies replies received</div>
        </div>
        <div class="rr-card">
            <div class="k">Quotes sent</div>
            <div class="v">@_quotesSent</div>
            <div class="foot">@_paymentPending awaiting payment</div>
        </div>
        <div class="rr-card">
            <div class="k">Work in progress</div>
            <div class="v">@_inProgress</div>
            <div class="foot">@_completedUnpaid completed, unpaid</div>
        </div>
        <div class="rr-card">
            <div class="k">Follow-ups due</div>
            <div class="v">@_followUps</div>
            <div class="foot">Scheduled reminders</div>
        </div>
    </div>

    <ActivityFeed @rendermode="InteractiveServer" />

    <div class="rr-panel">
        <div class="rr-panel-head">
            <h2>Top opportunities</h2>
            <a class="rr-btn sm" href="opportunities">All →</a>
        </div>
        @if (_top.Count == 0)
        {
            <div class="rr-empty">No active opportunities yet. Discovery runs automatically, or add one manually.</div>
        }
        else
        {
            <table class="rr-table">
                <thead>
                    <tr>
                        <th>Score</th><th>Priority</th><th>Opportunity</th><th>Stack</th>
                        <th title="Did the author ask for someone to actually help (vs. just information)?">Assistance requested</th>
                        <th title="Did the author indicate they'd pay someone to solve it?">Compensation offered</th>
                        <th>Fee</th><th>Age</th><th>Status</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var o in _top)
                    {
                        var assist = UiHelpers.YesNo(o.AssistanceRequested);
                        var comp = UiHelpers.YesNo(UiHelpers.CompensationOffered(o));
                        <tr>
                            <td><span class="rr-score">@o.Score.ToString("0")</span></td>
                            <td><span class="@UiHelpers.PriorityClass(o.Priority)">@o.Priority</span></td>
                            <td class="rr-title-cell">
                                <a href="opportunities/@o.Id">@o.Title</a>
                                <div class="src" style="font-style:italic;font-weight:400">@UiHelpers.LeadBlurb(o)</div>
                                <div class="src">
                                    @if (_campaign is null && o.CampaignId is { } cid && _campaignNames.TryGetValue(cid, out var cname))
                                    {
                                        <span>@cname · </span>
                                    }
                                    @o.SourceKey · @o.ProblemType
                                    · <a href="@o.SourceUrl" target="_blank" rel="noopener noreferrer">Original source ↗</a>
                                </div>
                            </td>
                            <td>@string.Join(", ", UiHelpers.ParseStringList(o.DetectedStackJson))</td>
                            <td><span class="@assist.Css">@assist.Label</span></td>
                            <td><span class="@comp.Css">@comp.Label</span></td>
                            <td>@UiHelpers.Fee(o)</td>
                            <td><span class="@UiHelpers.AgeClass(o.PostedAt)">@UiHelpers.Age(o.PostedAt)</span></td>
                            <td><span class="@UiHelpers.StatusClass(o.Status)">@UiHelpers.Spaced(o.Status)</span></td>
                        </tr>
                    }
                </tbody>
            </table>
        }
    </div>

    <div class="rr-panel">
        <div class="rr-panel-head">
            <div>
                <h2>Just missed</h2>
                <div class="rr-sub">Candidates that reached 50–99% of their source's required score. Kept for tuning, never auto-queued for outreach.</div>
            </div>
            <a class="rr-btn sm" href="opportunities">Review all →</a>
        </div>
        @if (_justMissed.Count == 0)
        {
            <div class="rr-empty">No near-threshold candidates in the current campaign yet.</div>
        }
        else
        {
            <div class="rr-table-scroll">
                <table class="rr-table">
                    <thead>
                        <tr>
                            <th>Score</th><th>Threshold fit</th><th>Opportunity</th><th>Intent</th>
                            <th>Score breakdown</th><th>Age</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var o in _justMissed)
                        {
                            var required = RequiredScore(o);
                            var percentage = required > 0 ? o.Score / required : 0;
                            var intent = o.PaymentIntent switch
                            {
                                "Explicit" => (Css: "rr-chip won", Label: "Paid"),
                                "Implied" => (Css: "rr-chip review", Label: "Networking"),
                                _ => (Css: "rr-chip", Label: "Unclear")
                            };
                            <tr>
                                <td>
                                    <span class="rr-score">@o.Score.ToString("0.#")</span>
                                    <div class="src">needs @required.ToString("0.#")</div>
                                </td>
                                <td><span class="rr-badge watch">@percentage.ToString("P0")</span></td>
                                <td class="rr-title-cell">
                                    <a href="opportunities/@o.Id">@o.Title</a>
                                    <div class="src" style="font-style:italic;font-weight:400">@UiHelpers.LeadBlurb(o)</div>
                                    <div class="src">
                                        @o.SourceKey · @o.ProblemType
                                        · <a href="@o.SourceUrl" target="_blank" rel="noopener noreferrer">Original source ↗</a>
                                    </div>
                                </td>
                                <td>
                                    <span class="@intent.Css">@intent.Label</span>
                                    @if (o.AssistanceRequested == true)
                                    {
                                        <div class="src">Hands-on help requested</div>
                                    }
                                </td>
                                <td>
                                    <span title="Urgency">U @o.UrgencyScore.ToString("0")</span> ·
                                    <span title="Business value">V @o.BusinessValueScore.ToString("0")</span> ·
                                    <span title="Reachability">R @o.ReachabilityScore.ToString("0")</span> ·
                                    <span title="Competition">C @o.CompetitionScore.ToString("0")</span> ·
                                    <span title="Trust">T @o.TrustScore.ToString("0")</span> ·
                                    <span title="Known-stack familiarity">K @o.StackFitScore.ToString("0")</span>
                                </td>
                                <td><span class="@UiHelpers.AgeClass(o.PostedAt)">@UiHelpers.Age(o.PostedAt)</span></td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    </div>
}

@code {
    private bool _loading = true;
    private int _criticalCount, _highCount, _draftsPending, _aiReview, _contacted, _replies,
                _quotesSent, _paymentPending, _inProgress, _completedUnpaid, _followUps;
    private List<Opportunity> _top = new();
    private List<Opportunity> _justMissed = new();
    private long? _campaignId;
    private Campaign? _campaign;
    private Dictionary<long, string> _campaignNames = new();
    private Dictionary<string, double> _sourceThresholds = new(StringComparer.OrdinalIgnoreCase);

    private static string Truncate(string s, int max) =>
        string.IsNullOrEmpty(s) ? "" : s.Length <= max ? s : s[..max] + "…";

    private static readonly OpportunityStatus[] Dead =
        { OpportunityStatus.Rejected, OpportunityStatus.PreFilteredRejected, OpportunityStatus.Lost,
          OpportunityStatus.DoNotContact, OpportunityStatus.Won, OpportunityStatus.Paid,
          OpportunityStatus.Archived, OpportunityStatus.JustMissed };

    protected override async Task OnInitializedAsync()
    {
        await using var db = await DbFactory.CreateDbContextAsync();
        var now = DateTimeOffset.UtcNow;

        var settings = await db.OperatorSettings.AsNoTracking().FirstOrDefaultAsync();
        _campaignId = settings?.SelectedCampaignId;
        _campaign = _campaignId is { } selected
            ? await db.Campaigns.AsNoTracking().FirstOrDefaultAsync(c => c.Id == selected)
            : null;
        if (_campaignId is not null && _campaign is null) _campaignId = null; // stale selection
        _campaignNames = await db.Campaigns.AsNoTracking()
            .ToDictionaryAsync(c => c.Id, c => $"{c.Emoji} {c.Name}");
        _sourceThresholds = await db.SourceConfigs.AsNoTracking()
            .ToDictionaryAsync(s => s.SourceKey, s => s.MinOpportunityScore, StringComparer.OrdinalIgnoreCase);

        // Campaign scope: every stat on this page honors the sidebar selection.
        var opps = _campaignId is { } cid ? db.Opportunities.Where(o => o.CampaignId == cid) : db.Opportunities;
        var freshCutoff = now.AddDays(-LeadQualityRules.MaxAutomatedLeadAgeDays);
        var freshOpps = opps.Where(o => o.SourceKey == "manual" || o.PostedAt >= freshCutoff);

        _criticalCount = await freshOpps.CountAsync(o => o.Priority == Priority.Critical && !Dead.Contains(o.Status));
        _highCount = await freshOpps.CountAsync(o => o.Score >= 70 &&
            (o.Status == OpportunityStatus.New || o.Status == OpportunityStatus.AiTriaged
             || o.Status == OpportunityStatus.NeedsReview || o.Status == OpportunityStatus.DraftReady));
        _draftsPending = _campaignId is { } dc
            ? await db.OutreachAttempts.CountAsync(a => a.Status == OutreachStatus.PendingApproval &&
                db.Opportunities.Any(o => o.Id == a.OpportunityId && o.CampaignId == dc))
            : await db.OutreachAttempts.CountAsync(a => a.Status == OutreachStatus.PendingApproval);
        _aiReview = await freshOpps.CountAsync(o => o.AiJobStatus == AiJobStatus.NeedsManualReview);
        _contacted = await opps.CountAsync(o => o.Status == OpportunityStatus.Contacted);
        _replies = await opps.CountAsync(o => o.Status == OpportunityStatus.Responded || o.Status == OpportunityStatus.Qualified);
        _quotesSent = _campaignId is { } qc
            ? await db.Quotes.CountAsync(q => (q.Status == QuoteStatus.Sent || q.Status == QuoteStatus.PaymentPending) &&
                db.Opportunities.Any(o => o.Id == q.OpportunityId && o.CampaignId == qc))
            : await db.Quotes.CountAsync(q => q.Status == QuoteStatus.Sent || q.Status == QuoteStatus.PaymentPending);
        _paymentPending = _campaignId is { } pc
            ? await db.Quotes.CountAsync(q => (q.Status == QuoteStatus.Sent || q.Status == QuoteStatus.Overdue) &&
                db.Opportunities.Any(o => o.Id == q.OpportunityId && o.CampaignId == pc))
            : await db.Quotes.CountAsync(q => q.Status == QuoteStatus.Sent || q.Status == QuoteStatus.Overdue);
        _inProgress = await opps.CountAsync(o => o.Status == OpportunityStatus.InProgress);
        _completedUnpaid = await opps.CountAsync(o => o.Status == OpportunityStatus.Fixed || o.Status == OpportunityStatus.PaymentPending);
        var followUpDates = await opps.AsNoTracking()
            .Where(o => o.NextFollowUpAt != null && o.Status != OpportunityStatus.Won && o.Status != OpportunityStatus.Lost)
            .Select(o => o.NextFollowUpAt).ToListAsync();
        _followUps = followUpDates.Count(f => f <= now);

        var topCandidates = await freshOpps.AsNoTracking()
            .Where(o => !Dead.Contains(o.Status))
            .OrderByDescending(o => o.Score).Take(50).ToListAsync();
        var topIds = topCandidates.Select(o => o.Id).ToHashSet();
        var rawBodies = await db.RawSourceItems.AsNoTracking()
            .Where(r => r.OpportunityId != null && topIds.Contains(r.OpportunityId.Value))
            .Select(r => new { r.OpportunityId, r.BodyText })
            .ToListAsync();
        var bodyByOpportunity = rawBodies
            .GroupBy(r => r.OpportunityId!.Value)
            .ToDictionary(g => g.Key, g => string.Join('\n', g.Select(r => r.BodyText)));

        _top = topCandidates
            .Where(o => IsDashboardLead(o, bodyByOpportunity))
            .DistinctBy(o => DashboardDuplicateKey(o, bodyByOpportunity))
            .Take(10)
            .ToList();

        var justMissedCandidates = await freshOpps.AsNoTracking()
            .Where(o => o.Status == OpportunityStatus.JustMissed)
            .OrderByDescending(o => o.Score)
            .Take(100)
            .ToListAsync();
        _justMissed = justMissedCandidates
            .Where(o => RequiredScore(o) > 0)
            .Where(o => o.Score / RequiredScore(o) is >= 0.5 and < 1)
            .OrderByDescending(o => o.Score / RequiredScore(o))
            .Take(10)
            .ToList();

        _loading = false;
    }

    private double RequiredScore(Opportunity opportunity) =>
        _sourceThresholds.GetValueOrDefault(opportunity.SourceKey);

    private static bool IsDashboardLead(Opportunity o, IReadOnlyDictionary<long, string> bodyByOpportunity)
    {
        bodyByOpportunity.TryGetValue(o.Id, out var body);
        var text = $"{o.Title}\n{o.Summary}\n{body}";
        return LeadQualityRules.IsDashboardWorthyLead(
            o.SourceKey,
            o.PaymentIntent,
            o.AssistanceRequested,
            o.FeeIsEstimate,
            text);
    }

    private static string DashboardDuplicateKey(Opportunity o, IReadOnlyDictionary<long, string> bodyByOpportunity)
    {
        bodyByOpportunity.TryGetValue(o.Id, out var body);
        var title = LeadQualityRules.NormalizeDuplicateTitle(o.Title);
        var host = LeadQualityRules.HostFromUrl(o.SourceUrl) ?? o.SourceKey;
        return $"{o.SourceKey}|{host}|{title}|{LeadQualityRules.IsNonHirableVendorSupportRequest($"{o.Title}\n{o.Summary}\n{body}")}";
    }
}
