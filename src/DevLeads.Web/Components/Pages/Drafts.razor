@page "/drafts"
@rendermode InteractiveServer
@inject IDbContextFactory<DevLeadsDbContext> DbFactory
@inject IServiceScopeFactory ScopeFactory
<PageTitle>Approval queue · DevLeads</PageTitle>

<div class="rr-page-head">
    <div>
        <h1>Approval queue</h1>
        <div class="rr-sub">Drafts awaiting your review. Nothing is ever sent automatically in HITL mode.</div>
    </div>
</div>

@if (_flash is not null) { <div class="rr-flash @(_flashOk ? "ok" : "err")">@_flash</div> }
@if (_generating) { <div class="rr-flash ok">⏳ Writing all queued responses in one batched AI call — usually a minute or two…</div> }

<div class="rr-panel">
    <div class="rr-panel-head">
        <h2>🪄 AI generation queue</h2>
        <button class="rr-btn primary" @onclick="GenerateQueued" disabled="@(_generating || _queued.Count == 0)">
            ⚡ Generate all (@_queued.Count queued · 1 AI call)
        </button>
    </div>
    @if (_queued.Count == 0)
    {
        <div class="rr-empty">Nothing queued. Queue leads with the 🪄 button on the Opportunities list or a lead's detail page; high-scoring leads queue automatically. The hourly background run also processes the queue.</div>
    }
    else
    {
        @foreach (var row in _queued)
        {
            <div style="display:flex;justify-content:space-between;align-items:center;padding:.3rem 0;border-bottom:1px solid var(--line)">
                <div>
                    <a href="opportunities/@row.Attempt.OpportunityId" style="font-weight:600">@row.Title</a>
                    <span class="rr-sub"> · queued @UiHelpers.Age(row.Attempt.CreatedAt)</span>
                </div>
                <button class="rr-btn sm danger" @onclick="() => Cancel(row.Attempt.Id)" disabled="@_generating">✖ Remove</button>
            </div>
        }
    }
</div>

<div class="rr-panel">
    @if (_items.Count == 0)
    {
        <div class="rr-empty">Nothing awaiting approval. High-score leads generate drafts automatically.</div>
    }
    else
    {
        @foreach (var row in _items)
        {
            <div style="border:1px solid var(--line);border-radius:8px;padding:.9rem;margin-bottom:.8rem">
                <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:.4rem">
                    <div>
                        <a href="opportunities/@row.Attempt.OpportunityId" style="font-weight:600">@row.Title</a>
                        <div class="rr-sub">
                            @row.Attempt.TemplateKey · @row.Attempt.Channel · @UiHelpers.Spaced(row.Attempt.Status)
                            · <a href="@row.SourceUrl" target="_blank" rel="noopener noreferrer">Original source ↗</a>
                        </div>
                    </div>
                    <span class="rr-score">@row.Score.ToString("0")</span>
                </div>
                <div class="rr-quote">@row.Attempt.Body</div>
                <div class="rr-btn-row" style="margin-top:.6rem">
                    @if (row.Attempt.Status == OutreachStatus.PendingApproval)
                    {
                        <button class="rr-btn sm good" @onclick="() => Approve(row.Attempt.Id)">✔ Approve</button>
                    }
                    <button class="rr-btn sm primary" @onclick="() => Send(row.Attempt.Id)">➤ Record sent</button>
                    <button class="rr-btn sm danger" @onclick="() => Cancel(row.Attempt.Id)">✖ Cancel</button>
                </div>
            </div>
        }
    }
</div>

@code {
    private record Row(OutreachAttempt Attempt, string Title, string SourceUrl, double Score);
    private List<Row> _items = new();
    private List<Row> _queued = new();
    private bool _generating;
    private string? _flash; private bool _flashOk = true;

    protected override async Task OnInitializedAsync() => await Load();

    private async Task Load()
    {
        await using var db = await DbFactory.CreateDbContextAsync();
        var campaignId = (await db.OperatorSettings.AsNoTracking().FirstOrDefaultAsync())?.SelectedCampaignId;
        var attempts = await db.OutreachAttempts.AsNoTracking()
            .Where(a => a.Status == OutreachStatus.PendingApproval || a.Status == OutreachStatus.Approved
                        || a.Status == OutreachStatus.QueuedForGeneration)
            .ToListAsync();
        var oppIds = attempts.Select(a => a.OpportunityId).Distinct().ToList();
        var opps = (await db.Opportunities.AsNoTracking().Where(o => oppIds.Contains(o.Id))
            .Select(o => new { o.Id, o.Title, o.SourceUrl, o.Score, o.CampaignId }).ToListAsync()).ToDictionary(o => o.Id);
        var rows = attempts
            .Where(a => campaignId is null ||
                        (opps.TryGetValue(a.OpportunityId, out var oc) && oc.CampaignId == campaignId))
            .Select(a => new Row(a,
                opps.TryGetValue(a.OpportunityId, out var o) ? o.Title : "(lead)",
                opps.TryGetValue(a.OpportunityId, out var o2) ? o2.SourceUrl : "",
                opps.TryGetValue(a.OpportunityId, out var o3) ? o3.Score : 0))
            .OrderByDescending(r => r.Score).ToList();
        _queued = rows.Where(r => r.Attempt.Status == OutreachStatus.QueuedForGeneration).ToList();
        _items = rows.Where(r => r.Attempt.Status != OutreachStatus.QueuedForGeneration).ToList();
    }

    private async Task GenerateQueued()
    {
        _generating = true; _flash = null;
        StateHasChanged();
        try
        {
            using var scope = ScopeFactory.CreateScope();
            var (generated, message) = await scope.ServiceProvider
                .GetRequiredService<OutreachService>().GenerateQueuedResponsesAsync(default);
            _flash = message; _flashOk = generated > 0;
            await Load();
        }
        catch (Exception ex) { _flash = ex.Message; _flashOk = false; }
        finally { _generating = false; }
    }

    private async Task Run(Func<OutreachService, Task> action, string ok)
    {
        _flash = null;
        try
        {
            using var scope = ScopeFactory.CreateScope();
            await action(scope.ServiceProvider.GetRequiredService<OutreachService>());
            _flash = ok; _flashOk = true;
            await Load();
        }
        catch (Exception ex) { _flash = ex.Message; _flashOk = false; }
    }

    private Task Approve(long id) => Run(s => s.ApproveAsync(id, default), "Approved.");
    private Task Cancel(long id) => Run(s => s.CancelAsync(id, default), "Cancelled.");
    private Task Send(long id) => Run(async s =>
    {
        var (sent, message) = await s.SendAsync(id, default);
        if (!sent) throw new InvalidOperationException(message);
    }, "Recorded as sent.");
}
