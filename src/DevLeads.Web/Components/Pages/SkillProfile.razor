@page "/skills"
@rendermode InteractiveServer
@inject IDbContextFactory<DevLeadsDbContext> DbFactory
<PageTitle>Skill profile · DevLeads</PageTitle>

<div class="rr-page-head">
    <div>
        <h1>Skill profile</h1>
        <div class="rr-sub">
            Languages, frameworks, applications, and capabilities you're experienced with.
            Used to score how well each lead fits you, to filter bounty/issue searches,
            and to describe you to the AI triage model. Weight: 3 = core expertise, 2 = strong, 1 = familiar.
        </div>
    </div>
    <div class="rr-btn-row">
        <button class="rr-btn primary" @onclick="SaveAll" disabled="@_busy">💾 Save all changes</button>
    </div>
</div>

@if (_flash is not null) { <div class="rr-flash @(_flashOk ? "ok" : "err")">@_flash</div> }

<div class="rr-panel">
    <div class="rr-panel-head">
        <h2>📄 Resume</h2>
        <div class="rr-sub">Stored once, available everywhere the app needs it — signup packs link to it for platforms that ask for a resume, and future features can attach or distribute it.</div>
    </div>
    @if (_resumeName is not null)
    {
        <div style="display:flex;gap:.8rem;align-items:center;flex-wrap:wrap;margin-bottom:.6rem">
            <span class="rr-chip won">📄 @_resumeName</span>
            <span class="rr-sub">@FormatSize(_resumeSize) · uploaded @(_resumeUploadedAt is { } up ? UiHelpers.Age(up) : "")</span>
            <a class="rr-btn sm" href="api/documents/resume" target="_blank" rel="noopener noreferrer">⬇ Download</a>
            <button class="rr-btn sm danger" @onclick="RemoveResume" disabled="@_busy">🗑 Remove</button>
        </div>
        <div class="rr-field">
            <label>Replace it (PDF, Word, or text · up to 15 MB)</label>
            <InputFile OnChange="UploadResume" accept=".pdf,.doc,.docx,.txt,.md,.rtf" disabled="@_busy" />
        </div>
    }
    else
    {
        <div class="rr-field">
            <label>Upload your resume (PDF, Word, or text · up to 15 MB)</label>
            <InputFile OnChange="UploadResume" accept=".pdf,.doc,.docx,.txt,.md,.rtf" disabled="@_busy" />
        </div>
    }
</div>

<div class="rr-panel">
    <h2>Add a skill</h2>
    <div class="rr-grid-2">
        <div class="rr-field">
            <label>Name (also the match text, e.g. "ASP.NET Core")</label>
            <input class="rr-input" @bind="_newName" list="skill-categories-names" />
        </div>
        <div class="rr-field">
            <label>Category</label>
            <input class="rr-input" @bind="_newCategory" list="skill-categories" />
            <datalist id="skill-categories">
                @foreach (var c in Categories) { <option value="@c" /> }
            </datalist>
        </div>
    </div>
    <div class="rr-grid-2">
        <div class="rr-field">
            <label>Weight</label>
            <select class="rr-input" @bind="_newWeight">
                <option value="3">3 — core expertise</option>
                <option value="2">2 — strong</option>
                <option value="1">1 — familiar</option>
            </select>
        </div>
        <div class="rr-field">
            <label>Aliases (optional, one per line — abbreviations, synonyms)</label>
            <textarea class="rr-textarea" style="min-height:44px" @bind="_newAliases"></textarea>
        </div>
    </div>
    <button class="rr-btn" @onclick="Add" disabled="@_busy">➕ Add skill</button>
</div>

@foreach (var group in _skills.GroupBy(s => s.Category).OrderBy(g => g.Key))
{
    <div class="rr-panel">
        <h2>@group.Key <span class="rr-sub">(@group.Count())</span></h2>
        <div class="rr-table-scroll">
            <table class="rr-table">
                <thead><tr><th>On</th><th>Skill</th><th>Weight</th><th>Aliases (one per line)</th><th></th></tr></thead>
                <tbody>
                    @foreach (var s in group.OrderByDescending(x => x.Weight).ThenBy(x => x.Name))
                    {
                        <tr>
                            <td><input type="checkbox" @bind="s.Enabled" /></td>
                            <td><input class="rr-input" @bind="s.Name" /></td>
                            <td>
                                <select class="rr-input" @bind="s.Weight">
                                    <option value="3">3 — core</option>
                                    <option value="2">2 — strong</option>
                                    <option value="1">1 — familiar</option>
                                </select>
                            </td>
                            <td><textarea class="rr-textarea" style="min-height:36px" @bind="s.Aliases"></textarea></td>
                            <td><button class="rr-btn sm" @onclick="() => Delete(s)" disabled="@_busy">🗑</button></td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
}

@code {
    private List<Skill> _skills = new();
    private bool _busy;
    private string? _flash; private bool _flashOk = true;
    private string _newName = ""; private string _newCategory = ""; private string _newAliases = "";
    private int _newWeight = 2;

    private IEnumerable<string> Categories => _skills.Select(s => s.Category).Distinct().OrderBy(c => c);

    private const long MaxResumeBytes = 15 * 1024 * 1024;
    private string? _resumeName;
    private long _resumeSize;
    private DateTimeOffset? _resumeUploadedAt;

    protected override async Task OnInitializedAsync() => await Load();

    private async Task Load()
    {
        await using var db = await DbFactory.CreateDbContextAsync();
        _skills = await db.Skills.AsNoTracking().ToListAsync();
        // Metadata only — never pull the blob just to render the page.
        var resume = await db.OperatorDocuments.AsNoTracking()
            .Where(d => d.Kind == OperatorDocument.ResumeKind)
            .Select(d => new { d.FileName, d.SizeBytes, d.UploadedAt })
            .FirstOrDefaultAsync();
        _resumeName = resume?.FileName;
        _resumeSize = resume?.SizeBytes ?? 0;
        _resumeUploadedAt = resume?.UploadedAt;
    }

    private async Task UploadResume(InputFileChangeEventArgs e)
    {
        _busy = true; _flash = null;
        try
        {
            var file = e.File;
            if (file.Size == 0) { _flash = "That file is empty."; _flashOk = false; return; }
            if (file.Size > MaxResumeBytes) { _flash = "Resume is over 15 MB — export a smaller PDF."; _flashOk = false; return; }

            await using var stream = file.OpenReadStream(MaxResumeBytes);
            using var buffer = new MemoryStream();
            await stream.CopyToAsync(buffer);

            await using var db = await DbFactory.CreateDbContextAsync();
            var doc = await db.OperatorDocuments
                .FirstOrDefaultAsync(d => d.Kind == OperatorDocument.ResumeKind);
            if (doc is null)
            {
                doc = new OperatorDocument { Kind = OperatorDocument.ResumeKind };
                db.OperatorDocuments.Add(doc);
            }
            doc.FileName = file.Name;
            doc.ContentType = string.IsNullOrWhiteSpace(file.ContentType) ? "application/octet-stream" : file.ContentType;
            doc.SizeBytes = file.Size;
            doc.Data = buffer.ToArray();
            doc.UploadedAt = DateTimeOffset.UtcNow;
            await db.SaveChangesAsync();
            _flash = $"Resume saved: {file.Name}. Signup packs for resume-requiring platforms now link to it."; _flashOk = true;
            await Load();
        }
        catch (Exception ex) { _flash = ex.Message; _flashOk = false; }
        finally { _busy = false; }
    }

    private async Task RemoveResume()
    {
        _busy = true; _flash = null;
        try
        {
            await using var db = await DbFactory.CreateDbContextAsync();
            var doc = await db.OperatorDocuments
                .FirstOrDefaultAsync(d => d.Kind == OperatorDocument.ResumeKind);
            if (doc is not null) { db.OperatorDocuments.Remove(doc); await db.SaveChangesAsync(); }
            _flash = "Resume removed."; _flashOk = true;
            await Load();
        }
        catch (Exception ex) { _flash = ex.Message; _flashOk = false; }
        finally { _busy = false; }
    }

    private static string FormatSize(long bytes) =>
        bytes >= 1024 * 1024 ? $"{bytes / (1024.0 * 1024):0.#} MB" : $"{bytes / 1024.0:0.#} KB";

    private async Task Add()
    {
        if (string.IsNullOrWhiteSpace(_newName)) { _flash = "Skill name is required."; _flashOk = false; return; }
        _busy = true; _flash = null;
        try
        {
            await using var db = await DbFactory.CreateDbContextAsync();
            db.Skills.Add(new Skill
            {
                Name = _newName.Trim(),
                Category = string.IsNullOrWhiteSpace(_newCategory) ? "Other" : _newCategory.Trim(),
                Weight = Math.Clamp(_newWeight, 1, 3),
                Aliases = _newAliases.Trim(),
                Enabled = true
            });
            await db.SaveChangesAsync();
            _flash = $"Added {_newName}."; _flashOk = true;
            _newName = ""; _newAliases = "";
            await Load();
        }
        catch (Exception ex) { _flash = ex.Message; _flashOk = false; }
        finally { _busy = false; }
    }

    private async Task SaveAll()
    {
        _busy = true; _flash = null;
        try
        {
            await using var db = await DbFactory.CreateDbContextAsync();
            foreach (var edited in _skills)
            {
                var s = await db.Skills.FindAsync(edited.Id);
                if (s is null) continue;
                s.Name = edited.Name.Trim();
                s.Weight = Math.Clamp(edited.Weight, 1, 3);
                s.Enabled = edited.Enabled;
                s.Aliases = edited.Aliases;
            }
            await db.SaveChangesAsync();
            _flash = "Skill profile saved. New leads are scored against it immediately."; _flashOk = true;
        }
        catch (Exception ex) { _flash = ex.Message; _flashOk = false; }
        finally { _busy = false; }
    }

    private async Task Delete(Skill skill)
    {
        _busy = true; _flash = null;
        try
        {
            await using var db = await DbFactory.CreateDbContextAsync();
            var s = await db.Skills.FindAsync(skill.Id);
            if (s is not null) { db.Skills.Remove(s); await db.SaveChangesAsync(); }
            _flash = $"Deleted {skill.Name}."; _flashOk = true;
            await Load();
        }
        catch (Exception ex) { _flash = ex.Message; _flashOk = false; }
        finally { _busy = false; }
    }
}
