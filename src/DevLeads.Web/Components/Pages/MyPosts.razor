    private async Task Save(OperatorPost edited)
    {
        await using var db = await DbFactory.CreateDbContextAsync();
        var p = await db.OperatorPosts.FirstOrDefaultAsync(x => x.Id == edited.Id);
        if (p is null) return;
        p.Notes = edited.Notes;
        p.Body = edited.Body;
        p.Url = edited.Url.Trim();
        // Adopt the reddit id from a pasted URL so the next sync recognizes this row
        // instead of importing the same post again (drafts/reposts start with a GUID).
        var idMatch = System.Text.RegularExpressions.Regex.Match(p.Url, @"/comments/([a-z0-9]+)", System.Text.RegularExpressions.RegexOptions.IgnoreCase);
        if (p.Platform == "reddit" && idMatch.Success && p.ExternalId != idMatch.Groups[1].Value)
            p.ExternalId = idMatch.Groups[1].Value;
        var newViews = Math.Max(0, edited.ViewCount);
        var newUpvotes = Math.Max(0, edited.UpvoteCount);
        // Manual counts are the only view data reddit allows — snapshot them so the
        // performance graph gets a point at every reading.
        if (newViews != p.ViewCount || newUpvotes != p.UpvoteCount)
        {
            db.OperatorPostSnapshots.Add(new OperatorPostSnapshot
            {
                OperatorPostId = p.Id, At = DateTimeOffset.UtcNow,
                ReplyCount = p.ReplyCount, UpvoteCount = newUpvotes, ViewCount = newViews
            });
        }
        p.ViewCount = newViews;
        p.UpvoteCount = newUpvotes;
        p.UpdatedAt = DateTimeOffset.UtcNow;
        await db.SaveChangesAsync();
        _flash = "Saved."; _flashOk = true;
        await Load();
    }

