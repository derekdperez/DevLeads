    /// <summary>
    /// The revision's "after" rate: a repost is measured over its own life, a body edit
    /// over the views/replies gained since the change. Compared against the frozen
    /// baseline rate, this is the experiment's readout.
    /// </summary>
    private (double ViewsPerDay, double RepliesPerDay)? AfterRate(OperatorPostRevision r)
    {
        if (r.AppliedAt is not { } appliedAt) return null;
        var now = DateTimeOffset.UtcNow;
        if (r.ResultPostId is { } resultId)
        {
            var repost = _posts.FirstOrDefault(p => p.Id == resultId);
            if (repost is null) return null;
            var life = Math.Max(1.0 / 24, (now - repost.PostedAt).TotalDays);
            return (repost.ViewCount / life, repost.ReplyCount / life);
        }
        var post = _posts.FirstOrDefault(p => p.Id == r.OperatorPostId);
        if (post is null) return null;
        var days = Math.Max(1.0 / 24, (now - appliedAt).TotalDays);
        return (Math.Max(0, post.ViewCount - r.BaselineViewCount) / days,
                Math.Max(0, post.ReplyCount - r.BaselineReplyCount) / days);
    }

    private static string Delta(double before, double after) =>
        before <= 0 ? "new" : $"{(after - before) / before * 100:+0;-0}%";

