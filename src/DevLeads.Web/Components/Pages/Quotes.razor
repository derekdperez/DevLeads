@page "/quotes"
@rendermode InteractiveServer
@inject IDbContextFactory<DevLeadsDbContext> DbFactory
@inject IServiceScopeFactory ScopeFactory
<PageTitle>Quotes &amp; payment · DevLeads</PageTitle>

<div class="rr-page-head">
    <div>
        <h1>Quotes &amp; payment</h1>
        <div class="rr-sub">Track the path from quote to fixed job to payment. @_outstanding outstanding · $@_pipeline.ToString("0") pipeline</div>
    </div>
</div>

@if (_flash is not null) { <div class="rr-flash @(_flashOk ? "ok" : "err")">@_flash</div> }

<div class="rr-panel">
    @if (_rows.Count == 0)
    {
        <div class="rr-empty">No quotes yet. Generate one from an opportunity's detail page.</div>
    }
    else
    {
        <table class="rr-table">
            <thead><tr><th>Amount</th><th>Opportunity</th><th>Terms</th><th>Status</th><th>Created</th><th></th></tr></thead>
            <tbody>
                @foreach (var r in _rows)
                {
                    <tr>
                        <td><strong>$@r.Quote.Amount.ToString("0")</strong></td>
                        <td class="rr-title-cell"><a href="opportunities/@r.Quote.OpportunityId">@r.Title</a></td>
                        <td>@(r.Quote.PaymentDueUponCompletion ? "On completion" : "Standard")</td>
                        <td><span class="@StatusChip(r.Quote.Status)">@UiHelpers.Spaced(r.Quote.Status)</span></td>
                        <td>@r.Quote.CreatedAt.LocalDateTime.ToString("MMM d")</td>
                        <td>
                            <div class="rr-btn-row">
                                @if (r.Quote.Status == QuoteStatus.Drafted) { <button class="rr-btn sm" @onclick="() => Send(r.Quote.Id)">Send</button> }
                                @if (r.Quote.Status is QuoteStatus.Sent or QuoteStatus.Overdue)
                                {
                                    <button class="rr-btn sm good" @onclick="() => Paid(r.Quote.Id)">Mark paid</button>
                                    <button class="rr-btn sm danger" @onclick="() => Overdue(r.Quote.Id)">Overdue</button>
                                }
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    }
</div>

@code {
    private record Row(Quote Quote, string Title);
    private List<Row> _rows = new();
    private double _pipeline; private int _outstanding;
    private string? _flash; private bool _flashOk = true;

    protected override async Task OnInitializedAsync() => await Load();

    private async Task Load()
    {
        await using var db = await DbFactory.CreateDbContextAsync();
        var quotes = await db.Quotes.AsNoTracking().OrderByDescending(q => q.CreatedAt).ToListAsync();
        var oppIds = quotes.Select(q => q.OpportunityId).Distinct().ToList();
        var titles = (await db.Opportunities.AsNoTracking().Where(o => oppIds.Contains(o.Id))
            .Select(o => new { o.Id, o.Title }).ToListAsync()).ToDictionary(o => o.Id, o => o.Title);
        _rows = quotes.Select(q => new Row(q, titles.TryGetValue(q.OpportunityId, out var t) ? t : "(lead)")).ToList();
        _outstanding = _rows.Count(r => r.Quote.Status is QuoteStatus.Sent or QuoteStatus.Overdue or QuoteStatus.PaymentPending);
        _pipeline = _rows.Where(r => r.Quote.Status is not (QuoteStatus.Paid or QuoteStatus.WrittenOff or QuoteStatus.Refunded))
            .Sum(r => r.Quote.Amount);
    }

    private static string StatusChip(QuoteStatus s) => s switch
    {
        QuoteStatus.Paid => "rr-chip won",
        QuoteStatus.Overdue or QuoteStatus.Disputed => "rr-chip review",
        QuoteStatus.Sent or QuoteStatus.PaymentPending => "rr-chip quote",
        QuoteStatus.WrittenOff => "rr-chip dead",
        _ => "rr-chip"
    };

    private async Task Run(Func<QuoteService, Task> action, string ok)
    {
        _flash = null;
        try
        {
            using var scope = ScopeFactory.CreateScope();
            await action(scope.ServiceProvider.GetRequiredService<QuoteService>());
            _flash = ok; _flashOk = true; await Load();
        }
        catch (Exception ex) { _flash = ex.Message; _flashOk = false; }
    }

    private Task Send(long id) => Run(s => s.SendAsync(id, default), "Quote sent.");
    private Task Paid(long id) => Run(s => s.MarkPaidAsync(id, default), "Marked paid. 🎉");
    private Task Overdue(long id) => Run(s => s.MarkOverdueAsync(id, default), "Marked overdue.");
}
